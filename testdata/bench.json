    },
    {
      "name": "100% reads 100B",
      "raftkv": {"ops": 28000, "p50": 0.4, "p99": 1.5},
      "etcd": {"ops": 35000, "p50": 0.3, "p99": 1.1}
    },
    {
      "name": "50/50 read-write 1KB",
      "raftkv": {"ops": 8500, "p50": 2.1, "p99": 8.3},
      "etcd": {"ops": 11000, "p50": 1.6, "p99": 6.2}
    }
  ],
  "methodology": {
    "fsync": "O_DIRECT on raftkv, default on etcd",
    "connections": 64,
    "duration": "30s per config, 3 runs averaged",
